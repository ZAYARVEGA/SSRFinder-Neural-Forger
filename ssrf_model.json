{
  "model_info": {
    "name": "SSRF Detector XGBoost",
    "version": "1.0",
    "algorithm": "GradientBoosting (XGBoost)",
    "accuracy": 1.0,
    "created": "2026-02-10"
  },
  
  "features": [
    "param_url",
    "param_webhook",
    "param_fetch",
    "endpoint_api",
    "endpoint_fetch",
    "endpoint_proxy",
    "endpoint_webhook",
    "is_https",
    "requires_auth",
    "method_post"
  ],
  
  "decision_rules": [
    {
      "feature": "param_url",
      "importance": 0.2658,
      "weight": 0.30,
      "description": "Parameter contiene 'url' - señal más fuerte"
    },
    {
      "feature": "endpoint_api",
      "importance": 0.1211,
      "weight": 0.15,
      "description": "Endpoint contiene '/api/'"
    },
    {
      "feature": "param_webhook",
      "importance": 0.1058,
      "weight": 0.12,
      "description": "Parameter contiene 'webhook'"
    },
    {
      "feature": "requires_auth",
      "importance": 0.1082,
      "weight": -0.11,
      "description": "Requiere autenticación (negativo = sin auth más vulnerable)"
    },
    {
      "feature": "endpoint_fetch",
      "importance": 0.0800,
      "weight": 0.10,
      "description": "Endpoint contiene 'fetch' o 'download'"
    },
    {
      "feature": "endpoint_webhook",
      "importance": 0.1058,
      "weight": 0.08,
      "description": "Endpoint contiene 'webhook'"
    },
    {
      "feature": "is_https",
      "importance": 0.0560,
      "weight": -0.06,
      "description": "HTTPS (negativo = HTTP más vulnerable)"
    },
    {
      "feature": "method_post",
      "importance": 0.0304,
      "weight": 0.05,
      "description": "Método POST"
    }
  ],
  
  "threshold": 0.5,
  
