  "feature_extraction_rules": {
    "param_url": {
      "pattern": ["url", "uri", "link"],
      "location": "parameter_name"
    },
    "param_webhook": {
      "pattern": ["webhook", "hook", "callback"],
      "location": "parameter_name"
    },
    "param_fetch": {
      "pattern": ["fetch", "stock", "get", "retrieve"],
      "location": "parameter_name"
    },
    "endpoint_api": {
      "pattern": ["/api/"],
      "location": "url_path"
    },
    "endpoint_fetch": {
      "pattern": ["fetch", "download", "import", "get"],
      "location": "url_path"
    },
    "endpoint_proxy": {
      "pattern": ["proxy"],
      "location": "url_path"
    },
    "endpoint_webhook": {
      "pattern": ["webhook", "hook", "callback"],
      "location": "url_path"
    },
    "is_https": {
      "pattern": ["https://"],
      "location": "url_protocol"
    },
    "requires_auth": {
      "check": "authentication_required",
      "location": "request_metadata"
    },
    "method_post": {
      "check": "method == POST",
      "location": "http_method"
    }
  },
  
  "usage_examples": [
    {
      "name": "Basic URL fetch",
      "request": {
        "url": "http://site.com/fetch?url=***",
        "method": "GET",
        "parameter_name": "url",
        "requires_auth": false
      },
      "expected_result": "VULNERABLE",
      "expected_confidence": 0.88,
      "top_payload": "http://localhost/admin"
    },
    {
      "name": "Webhook validator",
      "request": {
        "url": "http://api.site.com/webhooks/validate?webhookUrl=***",
        "method": "GET",
        "parameter_name": "webhookUrl",
        "requires_auth": false
      },
      "expected_result": "VULNERABLE",
      "expected_confidence": 0.85,
      "top_payload": "http://169.254.169.254/latest/meta-data/"
    },
    {
      "name": "Benign API",
      "request": {
        "url": "https://api.github.com/users/octocat/repos?page=1",
        "method": "GET",
        "parameter_name": "page",
        "requires_auth": true
      },
      "expected_result": "SAFE",
      "expected_confidence": 0.30,
      "top_payload": null
    }
  ]
